# ============================================================================
# .gitignore for pnpm monorepo
# Workspaces: classic (Win32/VS), desktop (Tauri), plus Node/Python/Go/Docker
# ============================================================================

# ----------------------------------------------------------------------------
# Operating Systems
# ----------------------------------------------------------------------------

# macOS
.DS_Store
._*

# Windows
Thumbs.db
Desktop.ini

# Linux / Emacs backup files
*~
.directory

# ----------------------------------------------------------------------------
# Node / JavaScript / TypeScript
# ----------------------------------------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Build output (if a workspace needs a tracked build/ or out/ dir, use !path in that dir)
dist/
dist-ssr/
build/
out/
.output/
.next/
.nuxt/
.nitro/
.data/
.svelte-kit/
.cache/

# Bundle analyzer
stats*.html

# Environment, secrets, and local config
.env
.env.*
*.env
.dev.vars
.dev.vars*
# *.vars and *.vars.* omitted — too broad (would match css.vars.ts, etc.)
# Add back if using Cloudflare Workers

# Local overrides (Vite convention)
*.local

# TypeScript
*.tsbuildinfo

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ESLint
.eslintcache

# Prettier
.prettiercache

# Testing
coverage/
.nyc_output/

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/

# Distribution / packaging
*.egg-info/
*.egg
*.whl

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.pytest_cache/

# mypy
.mypy_cache/

# ruff
.ruff_cache/

# pyenv
.python-version

# Jupyter
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# Rust
# ----------------------------------------------------------------------------

target/
**/*.rs.bk

# Note: Cargo.lock is committed — Tauri produces binaries, and Rust convention
# is to commit Cargo.lock for binary projects.

# ----------------------------------------------------------------------------
# Tauri (desktop workspace)
# ----------------------------------------------------------------------------

# desktop/src-tauri/target/ already covered by global target/ above
desktop/src-tauri/WixTools/
desktop/src-tauri/gen/
desktop/src-tauri/binaries/

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------

# Don't ignore Dockerfile or docker-compose.yml — those are source files.
# But do ignore runtime and build artifacts:
docker-compose.override.yml
.docker/

# ----------------------------------------------------------------------------
# Go
# ----------------------------------------------------------------------------

vendor/

# Note: go.sum is committed — same rationale as Cargo.lock for binaries.
# go.work.sum is also committed when using Go workspaces.

# ----------------------------------------------------------------------------
# Static Site Generators (Astro, VitePress, Docusaurus, Hugo, Nextra, etc.)
# ----------------------------------------------------------------------------

# Most SSG build output is already covered by dist/, build/, out/, .output/,
# .next/, .cache/ above. These catch framework-specific extras:
.docusaurus/
.astro/
.vitepress/cache/
.contentlayer/

# Hugo
resources/
.hugo_build.lock

# ----------------------------------------------------------------------------
# Visual Studio / Win32 (classic workspace)
# ----------------------------------------------------------------------------

# Build output
classic/Debug/
classic/Release/
classic/x64/
classic/x86/
classic/*.obj
classic/*.pdb
classic/*.ilk
classic/*.exp
classic/*.lib
classic/*.exe
classic/*.dll

# VS user and workspace files
classic/*.suo
classic/*.user
classic/*.ncb
classic/*.aps
classic/*.sdf
classic/*.opensdf
classic/*.opendb
classic/*.cachefile
classic/*.VC.db
classic/*.VC.opendb
classic/.vs/
classic/*.vcxproj.user

# Precompiled headers
classic/*.pch
classic/*.ipch
classic/ipch/

# IntelliSense
classic/*.ib_pdb_index

# ReSharper
classic/_ReSharper*/
classic/*.DotSettings.user

# ----------------------------------------------------------------------------
# IDEs and Editors
# ----------------------------------------------------------------------------

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (IntelliJ, WebStorm, RustRover, PyCharm, Fleet)
.idea/
.fleet/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
Session.vim

# Emacs (backup files covered by *~ above)
\#*\#
.#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# ----------------------------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------------------------

# Logs and diffs
logs/
*.log
*.diff
diff*.txt

# Secrets and credentials (never commit these)
*.pem
*.key
*.cert
*.p12
secrets/
credentials/

# Claude Code
.claude/

# Cross-project notes and deployment scripts (not for public repo)
*.hide.md
*.hide.sh
*.hide.*

# Gauge working state (written during local development)
ring.json

# Deployment platforms
.vercel/
.netlify/
.wrangler/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.orig

# Lock files — pnpm-lock.yaml SHOULD be committed
# package-lock.json and yarn.lock should not exist in a pnpm monorepo
package-lock.json
yarn.lock
